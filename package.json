{
  "name": "pi-claude-memory-extension",
  "version": "0.1.0",
  "description": "Claude-style persistent project memory for Pi, packaged as an installable Pi extension.",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "memory",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/san-tian/pi-claude-memory-extension.git"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@san-tian/pi-project-paths": "file:./vendor/pi-project-paths",
    "pi-codex-remote-compaction": "file:./vendor/pi-codex-remote-compaction",
    "pi-session-memory-extension": "file:./vendor/pi-session-memory-extension",
    "pi-subagent-tool": "file:./vendor/pi-subagent-tool"
  },
  "bundledDependencies": [
    "@san-tian/pi-project-paths",
    "pi-codex-remote-compaction",
    "pi-session-memory-extension",
    "pi-subagent-tool"
  ],
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions",
      "./vendor/pi-session-memory-extension/extensions",
      "./vendor/pi-codex-remote-compaction/index.ts"
    ]
  },
  "bundleDependencies": [
    "@san-tian/pi-project-paths",
    "pi-codex-remote-compaction",
    "pi-session-memory-extension",
    "pi-subagent-tool"
  ]
}
